DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@ep-xxxxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Railway/production: set APP_ENV=production so an empty FRONTEND_ORIGIN falls back to https://gauravtrades.de
APP_ENV=development
DEBUG=true
# Optional extra browser origins (comma-separated). FRONTEND_ORIGIN automatically adds both apex and www for that host.
CORS_ALLOW_ORIGINS=
MARKET_CACHE_TTL_SECONDS=45
MACRO_CACHE_TTL_SECONDS=900
MACRO_MARKET_SYMBOL=SPY
MACRO_USD_SYMBOL=UUP
MACRO_INTEREST_RATE_EFFECT=neutral
FINNHUB_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
SUPABASE_URL=
SUPABASE_ANON_KEY=
FRONTEND_ORIGIN=https://gauravtrades.de
OWNER_AUTH_SUBJECTS=
CRON_SECRET=

# --- Stripe (server-only: never expose STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET in the browser) ---
# Webhook endpoint (Stripe Dashboard): https://<YOUR_API_HOST>/api/billing/webhook
# Recommended events: checkout.session.completed, customer.subscription.created,
#   customer.subscription.updated, customer.subscription.deleted
STRIPE_SECRET_KEY=
# Signing secret from Stripe CLI or Dashboard for the webhook endpoint above
STRIPE_WEBHOOK_SECRET=
# Optional: Price ID (e.g. price_xxx). If empty, checkout uses inline price_data (EUR 4.99/mo) in code.
STRIPE_PRICE_ID=
# Optional: publishable key (pk_...) — only needed if you add Stripe.js / Elements later; hosted Checkout does not require it on the server.
STRIPE_PUBLISHABLE_KEY=
